# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem
Thumbs.db

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — keep secrets out of git; allow committing the example template
.env
.env.*
!.env.example

# Private org / staff directory (copy from config/staff.example.json)
/config/staff.json
# Minified staff JSON for pasting into host env vars (contains real staff data)
/config/staff.env.txt
# Importable .env file for host env vars (contains real staff data)
/config/staff-config.env

# Local import dumps (may contain organization content)
/import-data/

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# editor / local tooling
.idea/
.vscode/
*.swp
.cursor/

# local clones of sibling apps (separate projects — do not typecheck/build with REC)
/nrep-matrix-app
/NREP-HR-project
